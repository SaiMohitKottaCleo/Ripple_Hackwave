# Add at least one API key below. Judges can use either Anthropic OR Groq.
# The key never reaches browser code because requests go through the Vite proxy.

# Anthropic (Claude)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
VITE_CLAUDE_MODEL=claude-sonnet-4-5

# Groq (OpenAI-compatible endpoint)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# Optional provider preference: auto | anthropic | groq
# - auto: picks anthropic if available, else groq
VITE_AI_PROVIDER=auto
